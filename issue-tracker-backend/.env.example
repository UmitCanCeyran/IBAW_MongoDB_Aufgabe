# ── MongoDB Atlas Connection String ──────────────────────────────
# Aus Atlas: "Connect" -> "Drivers" -> String kopieren.
# UUU = dein DB-User, PPP = dein Passwort, XXX = dein Cluster-Host.
# Den Datenbanknamen (issuetracker) direkt vor das "?" schreiben.
MONGODB_URI=mongodb+srv://UUU:PPP@cluster0.XXX.mongodb.net/issuetracker?retryWrites=true&w=majority

# Port, auf dem der Express-Server lauscht
PORT=3000
